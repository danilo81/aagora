{
    "name": "@workspace/db",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./auth-db": {
            "types": "./dist/auth-db/index.d.ts",
            "default": "./dist/auth-db/index.js"
        },
        "./schema": {
            "types": "./dist/schema.d.ts",
            "default": "./dist/schema.js"
        },
        "./validation": {
            "types": "./dist/validation.d.ts",
            "default": "./dist/validation.js"
        }
    },
    "scripts": {
        "dev": "tsc --watch",
        "build": "tsc",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push"
    },
    "dependencies": {
        "@neondatabase/serverless": "latest",
        "drizzle-orm": "latest",
        "drizzle-zod": "latest",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^25.1.0",
        "drizzle-kit": "^0.31.10",
        "typescript": "^5.9.3"
    }
}