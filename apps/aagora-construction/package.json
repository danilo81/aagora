    "@clerk/nextjs": "^7.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/clipboard": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/three": "^0.184.1",
    "@workspace/auth": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/ui": "workspace:*",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lexical": "^0.44.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "svix": "^1.93.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^11.0.0",
    "web-ifc-three": "^0.0.126"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
